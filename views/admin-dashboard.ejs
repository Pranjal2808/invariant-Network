<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Invariant Network</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root{
      --bg:#0a0a0c;
      --card:#141417;
      --border:#27272a;
      --text:#e4e4e7;
      --muted:#9ca3af;
      --accent:#ffffff;
    }
    *{box-sizing:border-box;}
    body{
      margin:0;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      background:var(--bg);
      color:var(--text);
      line-height:1.7;
    }
    .container{
      max-width:1080px;
      margin:0 auto;
      padding:44px 22px 70px;
    }
    .top{
      display:flex;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
      align-items:center;
      margin-bottom:20px;
    }
    .top h1{
      margin:0;
      font-size:1.62rem;
      letter-spacing:-0.02em;
    }
    .top form{margin:0;}
    .logout{
      background:transparent;
      color:var(--text);
      border:1px solid var(--border);
      border-radius:10px;
      padding:9px 12px;
      cursor:pointer;
    }
    .logout:hover{border-color:#3a3a3a;}

    .alert{
      margin:0 0 14px;
      padding:11px 13px;
      border-radius:10px;
      border:1px solid var(--border);
      font-size:.93rem;
    }
    .alert.success{
      border-color:#25593a;
      background:#102117;
      color:#bde3c8;
    }
    .alert.error{
      border-color:#5a2a2a;
      background:#211212;
      color:#efc3c3;
    }

    .grid{
      display:grid;
      grid-template-columns:360px 1fr;
      gap:18px;
      align-items:start;
    }
    .card{
      background:linear-gradient(180deg,#151518,#111113);
      border:1px solid var(--border);
      border-radius:14px;
      padding:20px;
    }
    .card h2{
      margin:0 0 14px;
      font-size:1.12rem;
      letter-spacing:-0.01em;
    }
    label{
      display:block;
      margin-bottom:6px;
      color:var(--muted);
      font-size:.9rem;
    }
    input, textarea{
      width:100%;
      background:#0f0f12;
      border:1px solid var(--border);
      border-radius:10px;
      color:var(--text);
      padding:10px 12px;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      margin-bottom:12px;
    }
    textarea{
      min-height:120px;
      resize:vertical;
    }
    .btn{
      background:var(--accent);
      color:#000;
      border:none;
      border-radius:10px;
      padding:10px 14px;
      font-weight:600;
      cursor:pointer;
    }
    table{
      width:100%;
      border-collapse:collapse;
      font-size:.93rem;
    }
    th, td{
      text-align:left;
      padding:10px 8px;
      border-bottom:1px solid var(--border);
      vertical-align:top;
    }
    th{color:var(--muted);font-weight:500;}
    .table-link{
      color:var(--text);
      text-decoration:none;
      border:1px solid var(--border);
      border-radius:8px;
      padding:6px 9px;
      font-size:.82rem;
      display:inline-block;
    }
    .table-link:hover{border-color:#3a3a3a;}
    .empty{
      color:var(--muted);
      font-size:.93rem;
      margin-top:4px;
    }
    @media(max-width:980px){
      .grid{grid-template-columns:1fr;}
      table{display:block;overflow-x:auto;white-space:nowrap;}
    }
  </style>
</head>
<body>
  <main class="container">
    <div class="top">
      <h1>Admin Dashboard</h1>
      <form action="/admin/logout" method="post">
        <button class="logout" type="submit">Logout</button>
      </form>
    </div>

    <% if (success) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <section class="grid">
      <article class="card">
        <h2>Add Job</h2>
        <form action="/admin/jobs" method="post">
          <label for="title">Role Title</label>
          <input id="title" name="title" type="text" required />

          <label for="company">Company</label>
          <input id="company" name="company" type="text" required />

          <label for="location">Location</label>
          <input id="location" name="location" type="text" required />

          <label for="description">Description</label>
          <textarea id="description" name="description" required></textarea>

          <button class="btn" type="submit">Create Job</button>
        </form>
      </article>

      <article class="card">
        <h2>Jobs and Applications</h2>
        <% if (!jobs.length) { %>
          <p class="empty">No jobs added yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Company</th>
                <th>Location</th>
                <th>Applications</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% jobs.forEach((job) => { %>
                <tr>
                  <td><%= job.title %></td>
                  <td><%= job.company %></td>
                  <td><%= job.location %></td>
                  <td><%= job.application_count %></td>
                  <td>
                    <a class="table-link" href="/admin/jobs/<%= job.id %>/applications">View Applications</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </article>
    </section>
  </main>
</body>
</html>

