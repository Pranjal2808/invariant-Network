<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= job.title %> - Invariant Network</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    :root{
      --bg:#0a0a0c;
      --card:#141417;
      --border:#27272a;
      --text:#e4e4e7;
      --muted:#9ca3af;
      --accent:#ffffff;
    }

    *{box-sizing:border-box;}

    body{
      margin:0;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      background:var(--bg);
      color:var(--text);
      line-height:1.72;
    }

    .container{
      max-width:840px;
      margin:0 auto;
      padding:56px 22px 72px;
    }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:24px;
      flex-wrap:wrap;
    }

    .topbar a{
      color:var(--text);
      text-decoration:none;
      border:1px solid var(--border);
      border-radius:10px;
      padding:10px 14px;
      font-size:.92rem;
    }

    .topbar a:hover{
      border-color:#3a3a3a;
    }

    .card{
      background:linear-gradient(180deg,#151518,#111113);
      border:1px solid var(--border);
      border-radius:16px;
      padding:28px;
    }

    h1{
      margin:0 0 10px;
      letter-spacing:-0.02em;
      font-size:1.9rem;
    }

    .meta{
      margin:0 0 20px;
      color:var(--muted);
    }

    .description{
      margin:0 0 26px;
      white-space:pre-line;
    }

    .alert{
      margin:0 0 16px;
      padding:12px 14px;
      border-radius:10px;
      border:1px solid var(--border);
      font-size:.95rem;
    }

    .alert.success{
      border-color:#25593a;
      background:#102117;
      color:#bde3c8;
    }

    .alert.error{
      border-color:#5a2a2a;
      background:#211212;
      color:#efc3c3;
    }

    .apply-form{
      margin-top:22px;
      display:grid;
      grid-template-columns:1fr auto;
      gap:10px;
      align-items:end;
    }

    .apply-form label{
      display:block;
      margin-bottom:6px;
      color:var(--muted);
      font-size:.9rem;
    }

    .apply-form input{
      width:100%;
      background:#0f0f12;
      border:1px solid var(--border);
      border-radius:10px;
      color:var(--text);
      padding:10px 12px;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      font-size:.95rem;
    }

    .apply-form input:focus{
      outline:none;
      border-color:#4a4a4f;
    }

    .apply-btn{
      display:inline-block;
      text-decoration:none;
      background:var(--accent);
      color:#000;
      font-weight:600;
      border-radius:10px;
      padding:12px 18px;
      border:none;
      cursor:pointer;
    }

    .note{
      margin-top:10px;
      color:var(--muted);
      font-size:.87rem;
    }

    @media(max-width:680px){
      .apply-form{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>
<body>
  <main class="container">
    <div class="topbar">
      <strong>Invariant Network</strong>
      <a href="/jobs">Back to Jobs</a>
    </div>

    <section class="card">
      <% if (success) { %>
        <div class="alert success"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <h1><%= job.title %></h1>
      <p class="meta"><%= job.company %> | <%= job.location %></p>
      <p class="description"><%= job.description %></p>

      <form class="apply-form" action="/jobs/<%= job.id %>/apply" method="post">
        <div>
          <label for="candidate_email">Registered Candidate Email</label>
          <input id="candidate_email" name="candidate_email" type="email" required />
        </div>
        <button class="apply-btn" type="submit">Apply</button>
      </form>
      <p class="note">If you are not registered yet, complete candidate registration on the home page first.</p>
    </section>
  </main>
</body>
</html>
