<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8D0V4X1CBM"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "G-8D0V4X1CBM");
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invariant Network - Quantitative Talent</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <style>
    :root{
      --bg:#0a0a0c;
      --card:#141417;
      --border:#27272a;
      --text:#e4e4e7;
      --muted:#9ca3af;
      --accent:#ffffff;
    }

    *{box-sizing:border-box;}

    body{
      margin:0;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      background:var(--bg);
      color:var(--text);
      line-height:1.75;
    }

    .container{
      max-width:920px;
      margin:0 auto;
      padding:64px 22px;
    }

    .top-row{
      display:flex;
      justify-content:flex-end;
      margin-bottom:20px;
    }

    .jobs-link{
      color:var(--text);
      text-decoration:none;
      border:1px solid var(--border);
      border-radius:10px;
      padding:10px 14px;
      font-size:.9rem;
    }

    .jobs-link:hover{
      border-color:#3a3a3a;
    }

    .logo-container{
      text-align:center;
      margin-bottom:28px;
      padding-top:20px;
    }

    .logo-svg{
      max-width:280px;
      height:auto;
    }

    header{
      text-align:center;
      margin-bottom:48px;
    }

    .subtitle{
      color:var(--muted);
      max-width:640px;
      margin:0 auto;
      font-size:1.05rem;
    }

    .credibility{
      max-width:700px;
      margin:0 auto 56px;
      padding:34px;
      background:linear-gradient(180deg,#151518,#111113);
      border:1px solid var(--border);
      border-radius:16px;
      text-align:center;
    }

    .credibility h2{
      margin-bottom:18px;
      letter-spacing:-0.02em;
      font-size:1.45rem;
    }

    .credibility p{
      color:var(--muted);
      margin-bottom:16px;
    }

    .tabs{
      display:flex;
      justify-content:center;
      gap:12px;
      margin-bottom:32px;
    }

    .tab{
      padding:12px 26px;
      border-radius:8px;
      border:1px solid var(--border);
      background:transparent;
      color:var(--text);
      cursor:pointer;
      font-weight:500;
      transition:.2s;
    }

    .tab:hover{
      border-color:#3a3a3a;
    }

    .tab.active{
      background:var(--accent);
      color:#000;
    }

    .panel{
      display:none;
      background:var(--card);
      border:1px solid var(--border);
      border-radius:18px;
      padding:40px;
    }

    .panel.active{
      display:block;
    }

    .cta{
      margin-top:24px;
      padding:14px 30px;
      font-weight:600;
      border-radius:10px;
      border:none;
      background:white;
      color:black;
      cursor:pointer;
      transition:.2s;
    }

    .cta:hover{
      transform:translateY(-2px);
    }

    .alert{
      max-width:700px;
      margin:0 auto 18px;
      padding:12px 14px;
      border-radius:10px;
      border:1px solid var(--border);
      font-size:.95rem;
    }

    .alert.success{
      border-color:#25593a;
      background:#102117;
      color:#bde3c8;
    }

    .alert.error{
      border-color:#5a2a2a;
      background:#211212;
      color:#efc3c3;
    }

    .form-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
      margin-top:18px;
      text-align:left;
    }

    .form-grid .full{
      grid-column:1 / -1;
    }

    label{
      display:block;
      font-size:.88rem;
      color:var(--muted);
      margin-bottom:5px;
    }

    input, textarea{
      width:100%;
      background:#0f0f12;
      border:1px solid var(--border);
      border-radius:10px;
      color:var(--text);
      padding:10px 12px;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      font-size:.95rem;
    }

    textarea{
      min-height:130px;
      resize:vertical;
      line-height:1.55;
    }

    input:focus, textarea:focus{
      outline:none;
      border-color:#4a4a4f;
    }

    .contact{
      max-width:700px;
      margin:60px auto 20px;
      padding:28px;
      background:linear-gradient(180deg,#151518,#111113);
      border:1px solid var(--border);
      border-radius:16px;
      text-align:center;
    }

    .contact h2{
      margin-bottom:12px;
      letter-spacing:-0.02em;
    }

    .contact p{
      color:var(--muted);
      margin:6px 0;
    }

    .contact a{
      color:var(--text);
      text-decoration:none;
      font-weight:500;
    }

    .contact a:hover{
      text-decoration:underline;
    }

    footer{
      text-align:center;
      margin-top:40px;
      font-size:.8rem;
      color:var(--muted);
      opacity:.6;
    }

    @media(max-width:600px){
      .logo-svg{
        max-width:240px;
      }

      .panel{
        padding:26px;
      }

      .form-grid{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>

<body>
  <main class="container">
    <div class="top-row">
      <a class="jobs-link" href="/jobs">View Opportunities</a>
    </div>

    <div class="logo-container">
      <svg class="logo-svg" width="280" height="70" viewBox="0 0 280 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="0" y="10" width="6" height="50" fill="#ffffff" />
        <path d="M 20 10 L 20 60 M 20 10 L 50 60 M 50 10 L 50 60" stroke="#ffffff" stroke-width="6" />
        <text x="70" y="40" font-family="Inter, sans-serif" font-size="24" font-weight="600" fill="#ffffff">INVARIANT</text>
        <text x="70" y="57" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#666">NETWORK</text>
      </svg>
    </div>

    <header>
      <p class="subtitle">
        A selective network for quantitative talent spanning financial risk, quant finance, data science, and advanced analytics.
      </p>
    </header>

    <% if (success) { %>
      <div class="alert success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <section class="credibility">
      <h2>Search, guided by judgment</h2>
      <p>
        Invariant Network is built by professionals from quantitative and analytical backgrounds who understand the rigor these roles demand.
      </p>
      <p>
        Every candidate is assessed in depth, with close attention to the quality of their work and readiness for demanding environments.
      </p>
      <p>
        We are intentionally selective, and introductions are made only when there is clear alignment.
      </p>
    </section>

    <div class="tabs">
      <button class="tab active" onclick="showPanel('candidate', this)">Candidate Application</button>
      <button class="tab" onclick="showPanel('employer', this)">Employer Requirements</button>
    </div>

    <section id="candidate" class="panel active">
      <div style="max-width:640px;margin:0 auto;text-align:center;">
        <h2>Candidate Application</h2>
        <p style="color:var(--muted);">
          Register your profile for quantitative opportunities across finance, risk, and analytics.
        </p>

        <form class="form-grid" action="/candidates/register" method="post" enctype="multipart/form-data">
          <div>
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required />
          </div>

          <div>
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>

          <div>
            <label for="phone">Phone</label>
            <input id="phone" name="phone" type="text" required />
          </div>

          <div>
            <label for="years_of_experience">Years of Experience</label>
            <input id="years_of_experience" name="years_of_experience" type="number" min="0" required />
          </div>

          <div class="full">
            <label for="skills">Skills</label>
            <textarea id="skills" name="skills" required></textarea>
          </div>

          <div class="full">
            <label for="resume">Resume Upload (PDF/DOC/DOCX)</label>
            <input id="resume" name="resume" type="file" accept=".pdf,.doc,.docx" required />
          </div>

          <div class="full" style="text-align:center;">
            <button class="cta" type="submit">Submit Candidate Registration</button>
          </div>
        </form>
      </div>
    </section>

    <section id="employer" class="panel">
      <div style="max-width:640px;margin:0 auto;text-align:center;">
        <h2>Employer Requirements</h2>
        <p style="color:var(--muted);">
          Submit role mandates for quantitative hiring requirements.
        </p>

        <form class="form-grid" action="/employer/mandate" method="post">
          <div>
            <label for="company_name">Company Name</label>
            <input id="company_name" name="company_name" type="text" required />
          </div>

          <div>
            <label for="role_title">Role Title</label>
            <input id="role_title" name="role_title" type="text" required />
          </div>

          <div class="full">
            <label for="location">Location</label>
            <input id="location" name="location" type="text" required />
          </div>

          <div class="full">
            <label for="job_description">Job Description</label>
            <textarea id="job_description" name="job_description" required></textarea>
          </div>

          <div class="full" style="text-align:center;">
            <button class="cta" type="submit">Submit Employer Mandate</button>
          </div>
        </form>
      </div>
    </section>

    <section class="contact">
      <h2>Contact</h2>
      <p>Email:
        <a href="mailto:contact@invariantnetwork.com">contact@invariantnetwork.com</a>
      </p>
      <p>Phone:
        <a href="tel:+918976309787">+91 8976309787</a>
      </p>
    </section>

    <footer>
      Copyright 2026 Invariant Network | Independent initiative | Confidential submissions
    </footer>
  </main>

  <script>
    function showPanel(panelId, button){
      document.querySelectorAll(".panel").forEach((p) => p.classList.remove("active"));
      document.querySelectorAll(".tab").forEach((t) => t.classList.remove("active"));

      document.getElementById(panelId).classList.add("active");
      button.classList.add("active");
    }
  </script>
</body>
</html>
